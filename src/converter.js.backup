/**
 * Main DOM to Markdown Converter
 * Integrates detection, browser extraction, and markdown conversion
 * Now includes caching to prevent redundant URL processing
 */

const fs = require('fs');
const path = require('path');
const http = require('http');
const https = require('https');
const crypto = require('crypto');
const TurndownService = require('turndown');
const { PageTypeDetector } = require('./detector');
const { OpenClawBrowserWrapper } = require('./browser-wrapper');
const PlaywrightWrapper = require('./playwright-wrapper');
const CacheStore = require('./cache-store');
const PolitenessManager = require('./politeness');

class DomToMarkdownConverter {
  constructor(options = {}) {
    this.options = {
      // Methods
      usePlaywright: options.usePlaywright !== false,           // Use Playwright for SPAs (default if installed)
      useWebFetch: options.useWebFetch !== false,               // Use web_fetch for static pages
      useOpenClawBrowser: options.useOpenClawBrowser || false,  // Only as fallback (not recommended due to known issues)
      useFirecrawl: options.useFirecrawl || false,

      // Playwright settings (when usePlaywright = true)
      playwrightBrowser: options.playwrightBrowser || 'chromium', // 'chromium' | 'firefox' | 'webkit'
      playwrightHeadless: options.playwrightHeadless !== false,
      playwrightWaitUntil: options.playwrightWaitUntil || 'networkidle',
      playwrightTimeout: options.playwrightTimeout || 30000,
      playwrightRemoveElements: options.playwrightRemoveElements || [
        'script', 'style', 'noscript', 'iframe', 'svg',
        'nav', 'footer', 'header', 'aside'
      ],
      playwrightWaitTime: options.playwrightWaitTime || 2000,  // Additional wait for JavaScript
      playwrightRetryTimeoutErrors: options.playwrightRetryTimeoutErrors !== false, // default true
      playwrightMaxRetries: options.playwrightMaxRetries || 2,
      playwrightRetryDelay: options.playwrightRetryDelay || 1000,
      playwrightCookies: options.playwrightCookies || [],
      playwrightHeaders: options.playwrightHeaders || {},

      // Browser authentication (when useOpenClawBrowser = true)
      browserCookies: options.browserCookies || [],
      browserHeaders: options.browserHeaders || {},

      // Web fetch authentication (when useWebFetch = true)
      webFetchCookies: options.webFetchCookies || [],
      webFetchHeaders: options.webFetchHeaders || {},
      webFetchRetryNetworkErrors: options.webFetchRetryNetworkErrors !== false, // default true
      webFetchMaxRetries: options.webFetchMaxRetries || 2,
      webFetchRetryDelay: options.webFetchRetryDelay || 1000,

      // OpenClaw browser settings (when useOpenClawBrowser = true)
      headless: options.headless !== false,
      waitTime: options.waitTime || 5000,
      profile: options.profile || 'openclaw',

      // Conversion
      rawHtml: options.rawHtml || false,  // If true, saves raw HTML and disables cleaning
      removeElements: options.rawHtml ? [] : (options.removeElements || ['nav', 'footer', 'aside', 'script', 'style', 'iframe', 'noscript']),
      preserveStructure: options.preserveStructure !== false,
      customRules: options.customRules || [],

      // Image extraction
      downloadImages: options.downloadImages || false,
      imageMaxWidth: options.imageMaxWidth || 1200,
      imageMaxHeight: options.imageMaxHeight || 1200,
      imageQuality: options.imageQuality || 85,
      imageDownloadRetries: options.imageDownloadRetries || 3,
      imageDownloadRetryDelay: options.imageDownloadRetryDelay || 1000,
      imageOutputDir: options.imageOutputDir || 'images',

      // Output
      saveToFile: options.saveToFile !== false,
      outputDir: options.outputDir || path.join(process.cwd(), 'exports', 'dom-markdown'),

      // Cache
      useCache: options.useCache !== false,
      cacheTTL: options.cacheTTL || 24 * 60 * 60 * 1000, // 24 hours default
      cacheMaxEntries: options.cacheMaxEntries || 1000,
      cacheDebug: options.cacheDebug || false,

      // Politeness
      politeness: options.politeness || false,
      politenessOptions: options.politenessOptions || {},

      // Debug
      debug: options.debug || false,
      timeout: options.timeout || 60
    };

    // Backward compatibility: map useBrowserHeadless to useOpenClawBrowser
    if (options.useBrowserHeadless !== undefined && this.options.useOpenClawBrowser === undefined) {
      this.options.useOpenClawBrowser = options.useBrowserHeadless;
    }

    this.detector = new PageTypeDetector({ debug: this.options.debug });
    this.turndownService = this.createTurndownService();

    // Cache
    if (this.options.useCache) {
      this.cacheStore = new CacheStore({
        cacheDir: path.join(__dirname, '..', 'cache'),
        defaultTTL: this.options.cacheTTL,
        maxSize: this.options.cacheMaxEntries,
        debug: this.options.cacheDebug
      });
      this.log('Cache enabled');
    } else {
      this.cacheStore = null;
    }

    // Politeness manager
    if (this.options.politeness) {
      this.politenessManager = new PolitenessManager({
        respectRobotsTxt: true,
        requestDelay: 1000,
        ...this.options.politenessOptions,
      });
      this.log('Politeness manager enabled');
    } else {
      this.politenessManager = null;
    }

    // Stats
    this.stats = {
      totalRequests: 0,
      byType: {},
      byMethod: {},
      successes: 0,
      failures: 0,
      cacheHits: 0,
      cacheMisses: 0,
      startTime: Date.now()
    };

    // Downloaded images cache (URL -> relative local path)
    this.downloadedImagesCache = new Map();
  }

  /**
   * Check if Playwright is available (silent check)
   */
  isPlaywrightAvailable() {
    try {
      require('playwright');
      return true;
    } catch (error) {
      return false;
    }
  }

  /**
   * Check if sharp is available for image resizing
   */
  isSharpAvailable() {
    try {
      require('sharp');
      return true;
    } catch (error) {
      return false;
    }
  }

  /**
   * Ensure Playwright is available, throw clear error if not
   */
  ensurePlaywrightAvailable() {
    if (!this.isPlaywrightAvailable()) {
      throw new Error(
        'Playwright no está instalado. Para extraer contenido de SPAs (React, Vue, etc.), ' +
        'debes instalar las dependencias:\n' +
        '  cd /home/jarvis/.openclaw/workspace/skills/dom-to-markdown\n' +
        '  npm install\n' +
        'Esto instalará Playwright y Chromium automáticamente (~150 MB).'
      );
    }
  }

  /**
   * Extract language and direction from HTML
   */
  extractLanguageAndDirection(html) {
    const result = { language: null, direction: null };
    if (!html || typeof html !== 'string') {
      return result;
    }

    // Look for <html lang="...">
    const htmlLangMatch = html.match(/<html[^>]*\s+lang=["']([^"']+)["']/i);
    if (htmlLangMatch) {
      result.language = htmlLangMatch[1];
    }

    // Look for <html dir="...">
    const htmlDirMatch = html.match(/<html[^>]*\s+dir=["']([^"']+)["']/i);
    if (htmlDirMatch) {
      result.direction = htmlDirMatch[1];
    }

    // Fallback to <body lang="..."> or <body dir="...">
    if (!result.language) {
      const bodyLangMatch = html.match(/<body[^>]*\s+lang=["']([^"']+)["']/i);
      if (bodyLangMatch) {
        result.language = bodyLangMatch[1];
      }
    }
    if (!result.direction) {
      const bodyDirMatch = html.match(/<body[^>]*\s+dir=["']([^"']+)["']/i);
      if (bodyDirMatch) {
        result.direction = bodyDirMatch[1];
      }
    }

    // Normalize direction values
    if (result.direction) {
      result.direction = result.direction.toLowerCase();
      if (!['ltr', 'rtl', 'auto'].includes(result.direction)) {
        result.direction = null;
      }
    }

    return result;
  }

  /**
   * Create configured TurndownService instance
   */
  /**
   * Create configured TurndownService instance
   */
  createTurndownService() {
    const turndownService = new TurndownService({
      headingStyle: 'atx',
      codeBlockStyle: 'fenced',
      bulletListMarker: '-',
      emDelimiter: '*',
      strongDelimiter: '**',
      linkStyle: 'inlined',
      linkReferenceStyle: 'full'
    });

    const options = this.options;

    // Add custom rules
    // Only add removeNoise rule if we have elements to remove (not in rawHtml mode)
    if (options.removeElements && options.removeElements.length > 0) {
      turndownService.addRule('removeNoise', {
        filter: this.options.removeElements,
        replacement: () => ''
      });
    }

    turndownService.addRule('preserveImages', {
      filter: 'img',
      replacement: (content, node) => {
        const src = node.getAttribute('src') || '';
        const alt = node.getAttribute('alt') || '';
        const title = node.getAttribute('title') || '';

        if (!src) return '';

        let markdown = `![${alt}](${src})`;
        if (title) {
          markdown += ` "${title}"`;
        }

        return markdown + '\n\n';
      }
    });

    turndownService.addRule('preserveLinks', {
      filter: 'a',
      replacement: (content, node) => {
        const href = node.getAttribute('href') || '';
        const title = node.getAttribute('title') || '';

        if (!href || href.startsWith('javascript:')) {
          return content;
        }

        let markdown = `[${content}](${href})`;
        if (title) {
          markdown += ` "${title}"`;
        }

        return markdown;
      }
    });

    turndownService.addRule('table', {
      filter: 'table',
      replacement: function (content, node) {
        try {
          const rows = node.querySelectorAll('tr');
          if (rows.length === 0) {
            return '';
          }

          // Determine maximum columns
          let maxCols = 0;
          for (let i = 0; i < rows.length; i++) {
            const cells = rows[i].querySelectorAll('td, th');
            let rowCols = 0;
            for (let j = 0; j < cells.length; j++) {
              const cell = cells[j];
              const colspan = parseInt(cell.getAttribute('colspan') || '1', 10);
              rowCols += colspan;
            }
            if (rowCols > maxCols) maxCols = rowCols;
          }

          if (maxCols === 0) {
            return '';
          }

          // Initialize grid and occupation matrix
          const grid = Array.from({ length: rows.length }, () => Array(maxCols).fill(''));
          const alignGrid = Array.from({ length: rows.length }, () => Array(maxCols).fill(null));
          const occupied = Array.from({ length: rows.length }, () => Array(maxCols).fill(false));

          // Fill grid
          for (let r = 0; r < rows.length; r++) {
            const cells = rows[r].querySelectorAll('td, th');
            let c = 0;
            // Find first free column in this row
            while (c < maxCols && occupied[r][c]) c++;

            for (let cellIdx = 0; cellIdx < cells.length; cellIdx++) {
              const cell = cells[cellIdx];
              const colspan = parseInt(cell.getAttribute('colspan') || '1', 10);
              const rowspan = parseInt(cell.getAttribute('rowspan') || '1', 10);
              let cellText = cell.textContent || '';
              // Escape pipe characters and newlines
              cellText = cellText.replace(/\|/g, '\\|').replace(/[\n\r]+/g, ' ').trim();
              const align = cell.getAttribute('align') || null; // left, center, right

              // Fill this cell and spanned cells
              for (let rs = 0; rs < rowspan; rs++) {
                for (let cs = 0; cs < colspan; cs++) {
                  const targetR = r + rs;
                  const targetC = c + cs;
                  if (targetR < rows.length && targetC < maxCols) {
                    occupied[targetR][targetC] = true;
                    // Only set text for the top-left cell
                    if (rs === 0 && cs === 0) {
                      grid[targetR][targetC] = cellText;
                    } else {
                      grid[targetR][targetC] = ''; // spanned cells empty
                    }
                    // Propagate alignment to all spanned cells
                    alignGrid[targetR][targetC] = align;
                  }
                }
              }
              c += colspan;
            }
          }

          // Determine alignment per column (pick first non-null alignment per column)
          const columnAlignments = Array(maxCols).fill(null);
          for (let c = 0; c < maxCols; c++) {
            for (let r = 0; r < rows.length; r++) {
              if (alignGrid[r][c] !== null) {
                columnAlignments[c] = alignGrid[r][c];
                break;
              }
            }
          }

          // Build markdown table
          let markdown = '';
          for (let r = 0; r < rows.length; r++) {
            const row = grid[r];
            markdown += '| ' + row.join(' | ') + ' |\n';
            // Add header separator after first row (assuming first row is header)
            if (r === 0) {
              const separatorParts = [];
              for (let c = 0; c < maxCols; c++) {
                const align = columnAlignments[c];
                if (align === 'center') {
                  separatorParts.push(':---:');
                } else if (align === 'right') {
                  separatorParts.push('---:');
                } else if (align === 'left') {
                  separatorParts.push(':---');
                } else {
                  separatorParts.push('---'); // default left
                }
              }
              markdown += '| ' + separatorParts.join(' | ') + ' |\n';
            }
          }

          return markdown + '\n';
        } catch (error) {
          // If something goes wrong, fallback to default conversion (content)
          // Log error only if debug is enabled
          if (options.debug) {
            console.error('[DOM→Markdown] Table conversion error:', error.message);
          }
          return content;
        }
      }
    });

    turndownService.addRule('codeBlocks', {
      filter: 'pre',
      replacement: function (content, node) {
        // Determine language from class attribute of <pre> or child <code>
        let language = '';

        // Check <pre> class
        const preClass = node.getAttribute('class') || '';
        let langMatch = preClass.match(/(?:language|lang)-(\w+)/);
        if (langMatch) {
          language = langMatch[1];
        }

        // If no language on <pre>, check child <code> element
        if (!language) {
          const codeElement = node.querySelector('code');
          if (codeElement) {
            const codeClass = codeElement.getAttribute('class') || '';
            langMatch = codeClass.match(/(?:language|lang)-(\w+)/);
            if (langMatch) {
              language = langMatch[1];
            }
          }
        }

        // Trim trailing newline from content
        const codeContent = content.replace(/\n$/, '');

        // Return fenced code block with language if detected
        if (language) {
          return `\`\`\`${language}\n${codeContent}\n\`\`\`\n\n`;
        } else {
          return `\`\`\`\n${codeContent}\n\`\`\`\n\n`;
        }
      }
    });

    // Preserve dir attribute for RTL text and other directional content
    turndownService.addRule('preserveDirection', {
      filter: function (node) {
        // Match any element with a dir attribute
        return node.hasAttribute && node.hasAttribute('dir');
      },
      replacement: function (content, node) {
        const dir = node.getAttribute('dir');
        if (!dir) return content;

        // Add comment before the element to preserve direction information
        // For block elements, add comment on its own line
        const blockElements = ['DIV', 'P', 'H1', 'H2', 'H3', 'H4', 'H5', 'H6', 'UL', 'OL', 'LI', 'SECTION', 'ARTICLE', 'HEADER', 'FOOTER', 'NAV', 'MAIN', 'ASIDE', 'BLOCKQUOTE', 'PRE', 'TABLE', 'FIGURE', 'FIGCAPTION'];
        const isBlock = blockElements.includes(node.nodeName);

        if (isBlock) {
          return `<!-- dir: ${dir} -->\n${content}\n`;
        } else {
          // Inline element - add comment before content (no extra newlines)
          return `<!-- dir: ${dir} -->${content}`;
        }
      }
    });

    // Preserve accessibility attributes (ARIA labels, roles, etc.)
    turndownService.addRule('preserveAccessibility', {
      filter: function (node) {
        // Match any element with accessibility attributes
        return node.hasAttribute && (
          node.hasAttribute('aria-label') ||
          node.hasAttribute('aria-labelledby') ||
          node.hasAttribute('aria-describedby') ||
          node.hasAttribute('role')
        );
      },
      replacement: function (content, node) {
        // Collect accessibility attributes
        const attrs = [];
        const ariaLabel = node.getAttribute('aria-label');
        const ariaLabelledby = node.getAttribute('aria-labelledby');
        const ariaDescribedby = node.getAttribute('aria-describedby');
        const role = node.getAttribute('role');
        
        if (ariaLabel) attrs.push(`aria-label="${ariaLabel}"`);
        if (ariaLabelledby) attrs.push(`aria-labelledby="${ariaLabelledby}"`);
        if (ariaDescribedby) attrs.push(`aria-describedby="${ariaDescribedby}"`);
        if (role) attrs.push(`role="${role}"`);
        
        if (attrs.length === 0) return content;
        
        const comment = `<!-- ${attrs.join(' ')} -->`;
        
        // Determine if block element (same as preserveDirection)
        const blockElements = ['DIV', 'P', 'H1', 'H2', 'H3', 'H4', 'H5', 'H6', 'UL', 'OL', 'LI', 'SECTION', 'ARTICLE', 'HEADER', 'FOOTER', 'NAV', 'MAIN', 'ASIDE', 'BLOCKQUOTE', 'PRE', 'TABLE', 'FIGURE', 'FIGCAPTION'];
        const isBlock = blockElements.includes(node.nodeName);
        
        if (isBlock) {
          return comment + '\n' + content + '\n';
        } else {
          return comment + content;
        }
      }
    });

    // Add custom rules if provided
    if (options.customRules && Array.isArray(options.customRules)) {
      options.customRules.forEach((rule, index) => {
        if (rule.filter && rule.replacement) {
          const ruleName = rule.name || `customRule${index}`;
          turndownService.addRule(ruleName, rule);
        } else {
          this.log(`Invalid custom rule at index ${index}: missing filter or replacement`);
        }
      });
    }

    return turndownService;
  }

  /**
   * Log message if debug enabled
   */
  log(message) {
    if (this.options.debug) {
      console.log(`[DOM→Markdown] ${message}`);
    }
  }

  /**
   * Update statistics
   */
  updateStats(pageType, method, success) {
    this.stats.totalRequests++;

    // Update by type
    this.stats.byType[pageType] = (this.stats.byType[pageType] || 0) + 1;

    // Update by method
    this.stats.byMethod[method] = (this.stats.byMethod[method] || 0) + 1;

    // Update success/failure
    if (success) {
      this.stats.successes++;
    } else {
      this.stats.failures++;
    }
  }

  /**
   * Get statistics
   */
  getStats() {
    const duration = Date.now() - this.stats.startTime;
    const successRate = this.stats.totalRequests > 0
      ? (this.stats.successes / this.stats.totalRequests) * 100
      : 0;

    // Cache hit rate
    const totalCacheLookups = (this.stats.cacheHits || 0) + (this.stats.cacheMisses || 0);
    const cacheHitRate = totalCacheLookups > 0
      ? ((this.stats.cacheHits || 0) / totalCacheLookups) * 100
      : 0;

    return {
      ...this.stats,
      durationMs: duration,
      successRate: parseFloat(successRate.toFixed(2)),
      cacheHitRate: parseFloat(cacheHitRate.toFixed(2)),
      cacheLookups: totalCacheLookups,
      requestsPerMinute: duration > 0
        ? (this.stats.totalRequests / (duration / 60000)).toFixed(2)
        : 0
    };
  }

  /**
   * Adjust line breaks for CJK text to prevent awkward wrapping
   */
  _adjustCjkLineBreaks(text) {
    // CJK Unicode ranges: Han, Hiragana, Katakana, Hangul
    const cjkRanges = [
      [0x4e00, 0x9fff],   // CJK Unified Ideographs
      [0x3040, 0x309f],   // Hiragana
      [0x30a0, 0x30ff],   // Katakana
      [0xac00, 0xd7af],   // Hangul
    ];
    
    // Insert zero-width space after each CJK character to allow line breaks
    let result = '';
    for (let i = 0; i < text.length; i++) {
      const char = text[i];
      let isCjk = false;
      const code = char.charCodeAt(0);
      for (const [start, end] of cjkRanges) {
        if (code >= start && code <= end) {
          isCjk = true;
          break;
        }
      }
      result += char;
      if (isCjk && i < text.length - 1) {
        // Add zero-width space after CJK character (break opportunity)
        result += '\u200B';
      }
    }
    return result;
  }

  /**
   * Convert HTML to markdown
   */
  convertHtmlToMarkdown(html) {
    try {
      if (!html || html.length < 10) {
        return '# No content\n\nUnable to convert empty HTML.';
      }

      const markdown = this.turndownService.turndown(html);
      return this._adjustCjkLineBreaks(markdown);
    } catch (error) {
      this.log(`HTML to markdown conversion error: ${error.message}`);

      // Fallback: extract text only
      const textOnly = html
        .replace(/<[^>]*>/g, ' ')  // Remove tags
        .replace(/\s+/g, ' ')      // Normalize whitespace
        .trim();

      const adjustedText = this._adjustCjkLineBreaks(textOnly);
      return `# Extracted Text\n\n${adjustedText.substring(0, 5000)}`;
    }
  }

  /**
   * Save result to file
   */
  saveResult(url, markdown, metadata, rawHtml = null) {
    if (!this.options.saveToFile) {
      return null;
    }

    try {
      // Create directory structure: YYYY-MM-DD/domain.com/
      const timestamp = new Date();
      const dateStr = timestamp.toISOString().split('T')[0];
      const urlObj = new URL(url);
      const domain = urlObj.hostname.replace(/^www\./, '');

      const outputDir = path.join(
        this.options.outputDir,
        dateStr,
        domain
      );

      // Create directory
      if (!fs.existsSync(outputDir)) {
        fs.mkdirSync(outputDir, { recursive: true });
      }

      // Create filename from path
      const pathname = urlObj.pathname.replace(/\//g, '-').replace(/^-|-$/g, '') || 'homepage';
      const filename = `${pathname}.md`;
      const filePath = path.join(outputDir, filename);

      // Save markdown
      fs.writeFileSync(filePath, markdown);

      // Prepare metadata
      const metadataPath = path.join(outputDir, 'metadata.json');
      const allMetadata = {};
      const fileMetadata = {
        url,
        timestamp: timestamp.toISOString(),
        markdownLength: markdown.length,
        ...metadata
      };

      // Save raw HTML if requested
      let rawHtmlPath = null;
      if (this.options.rawHtml && rawHtml && rawHtml.length > 0) {
        const rawFilename = `${pathname}.raw.html`;
        rawHtmlPath = path.join(outputDir, rawFilename);
        fs.writeFileSync(rawHtmlPath, rawHtml);
        this.log(`Raw HTML saved to: ${rawHtmlPath} (${rawHtml.length} bytes)`);

        // Add raw HTML info to metadata
        fileMetadata.rawHtmlPath = rawHtmlPath;
        fileMetadata.rawHtmlLength = rawHtml.length;
      }

      allMetadata[filename] = fileMetadata;

      // Append to existing metadata or create new
      if (fs.existsSync(metadataPath)) {
        const existing = JSON.parse(fs.readFileSync(metadataPath, 'utf8'));
        existing[filename] = allMetadata[filename];
        fs.writeFileSync(metadataPath, JSON.stringify(existing, null, 2));
      } else {
        fs.writeFileSync(metadataPath, JSON.stringify(allMetadata, null, 2));
      }

      return filePath;

    } catch (error) {
      this.log(`Failed to save result: ${error.message}`);
      return null;
    }
  }

  /**
   * Extract content using web_fetch (actual OpenClaw tool when available)
   */
  async extractWithWebFetch(url, suggestion = {}) {
    this.log(`Using web_fetch for ${url}`);

    // Determine headers and cookies for authentication
    const headers = suggestion.headers || this.options.webFetchHeaders || {};
    const cookies = suggestion.cookies || this.options.webFetchCookies || [];

    // Prepare cookie header from cookies array
    const cookieHeader = cookies.map(c => `${c.name}=${c.value}`).join('; ');
    if (cookieHeader) {
      headers['Cookie'] = cookieHeader;
    }

    // Try OpenClaw web_fetch tool first (if we're in OpenClaw agent context)
    if (typeof web_fetch === 'function') {
      try {
        const fetchOptions = {
          url,
          extractMode: 'text',
          maxChars: 1000000 // Large enough for full page
        };
        // Add headers and cookies if web_fetch supports them
        if (Object.keys(headers).length > 0) {
          fetchOptions.headers = headers;
        }
        if (cookies.length > 0) {
          fetchOptions.cookies = cookies;
        }

        const result = await web_fetch(fetchOptions);

        let html = '';
        if (result && result.rawHtml) {
          html = result.rawHtml;
          this.log(`Got raw HTML via web_fetch (${html.length} bytes)`);
        } else if (result && result.content) {
          // If we only have extracted text, wrap it in a simple HTML structure
          // This is less ideal but still usable for conversion
          html = `<html><body><pre>${result.content}</pre></body></html>`;
          this.log(`Got extracted text via web_fetch (${result.content.length} chars), wrapping in HTML`);
        } else {
          throw new Error('web_fetch returned no usable content');
        }

        return {
          method: 'web_fetch',
          html,
          raw: html,
          length: html.length,
          metadata: result,
          simulated: false,
          headers,
          cookies
        };
      } catch (error) {
        this.log(`web_fetch tool failed: ${error.message}`);
        // Fall through to fallback methods
      }
    }

    // Fallback: global fetch (Node 18+ or browser)
    if (typeof fetch === 'function') {
      try {
        const fetchOptions = {
          headers: {
            'User-Agent': 'OpenClaw-DOM-to-Markdown/1.0',
            ...headers
          },
          timeout: this.options.timeout * 1000 || 30000
        };

        const response = await fetch(url, fetchOptions);

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const html = await response.text();
        this.log(`Fetched ${html.length} bytes via global fetch`);

        return {
          method: 'web_fetch',
          html,
          raw: html,
          length: html.length,
          simulated: false,
          headers,
          cookies
        };
      } catch (error) {
        this.log(`Global fetch failed: ${error.message}`);
      }
    }

    // Final fallback: simulation (for testing/offline)
    this.log('No fetch method available, using simulation');
    const simulatedHtml = `<html><body><h1>Web Fetch Simulation</h1><p>URL: ${url}</p><p>In OpenClaw, this would use the web_fetch tool.</p></body></html>`;

    return {
      method: 'web_fetch',
      html: simulatedHtml,
      raw: 'Simulated web_fetch content',
      length: 100,
      simulated: true
    };
  }

  /**
   * Extract content using OpenClaw browser
   */
  async extractWithBrowserHeadless(url, suggestion) {
    this.log(`Using OpenClaw browser for ${url}`);

    try {
      const browserWrapper = new OpenClawBrowserWrapper({
        profile: this.options.profile,
        headless: this.options.headless,
        timeout: this.options.timeout,
        waitForLoad: suggestion.waitFor || 'networkidle',
        waitTime: this.options.waitTime,
        debug: this.options.debug,
        cookies: this.options.browserCookies,
        headers: this.options.browserHeaders
      });

      const result = await browserWrapper.extractFromUrl(url, {
        extractText: false,
        takeScreenshot: this.options.debug
      });

      if (!result.success) {
        throw new Error(`Browser extraction failed: ${result.error}`);
      }

      return {
        method: 'browser_headless',
        html: result.html,
        raw: result.html,
        length: result.html.length,
        metadata: result.metadata,
        screenshot: result.screenshot,
        simulated: false
      };

    } catch (error) {
      this.log(`Browser extraction error: ${error.message}`);

      // Fallback to web_fetch
      return await this.extractWithWebFetch(url, {});
    }
  }
  /**
   * Extract content using Playwright
   */
  async extractWithPlaywright(url, suggestion) {
    this.log(`Using Playwright for ${url}`);

    const maxRetries = this.options.playwrightMaxRetries;
    const retryDelay = this.options.playwrightRetryDelay;
    const retryTimeoutErrors = this.options.playwrightRetryTimeoutErrors;

    let lastError = null;

    for (let attempt = 1; attempt <= maxRetries + 1; attempt++) {
      try {
        // Ensure Playwright is available
        this.ensurePlaywrightAvailable();

        const playwrightWrapper = new PlaywrightWrapper({
          browserType: this.options.playwrightBrowser,
          headless: this.options.playwrightHeadless,
          waitUntil: this.options.playwrightWaitUntil,
          timeout: this.options.playwrightTimeout,
          waitTime: this.options.playwrightWaitTime,
          removeElements: this.options.playwrightRemoveElements,
          cookies: this.options.playwrightCookies,
          headers: this.options.playwrightHeaders,
          debug: this.options.debug
        });

        const result = await playwrightWrapper.extractFromUrl(url, {
          saveRawHtml: this.options.rawHtml
        });

        if (!result.success) {
          throw new Error(`Playwright extraction failed: ${result.error}`);
        }

        return {
          method: 'playwright',
          html: result.html,
          raw: result.html,
          length: result.html.length,
          metadata: result.metadata,
          savedFiles: result.savedFiles,
          simulated: false
        };

      } catch (error) {
        lastError = error;
        this.log(`Playwright extraction attempt ${attempt} failed: ${error.message}`);

        // Check if we should retry
        const shouldRetry = retryTimeoutErrors &&
                            (error.message.toLowerCase().includes('timeout')) &&
                            attempt <= maxRetries;

        if (shouldRetry) {
          this.log(`Retrying after ${retryDelay}ms...`);
          await new Promise(resolve => setTimeout(resolve, retryDelay));
          continue;
        }

        // No retry, break out of loop
        break;
      }
    }

    // If we reach here, all retries failed or error not retryable
    this.log(`Playwright extraction failed after retries: ${lastError.message}`);

    // Fallback to OpenClaw browser if enabled
    if (this.options.useOpenClawBrowser) {
      this.log('Falling back to OpenClaw browser...');
      return await this.extractWithBrowserHeadless(url, suggestion);
    }

    // Final fallback to web_fetch
    return await this.extractWithWebFetch(url, {});
  }

  /**
   * Main method: convert URL to markdown
   */
  async convertUrlToMarkdown(url, userOptions = {}) {
    const startTime = Date.now();
    const options = { ...this.options, ...userOptions };

    this.log(`Processing: ${url}`);

    try {
      // Politeness check
      if (this.politenessManager) {
        const allowed = await this.politenessManager.isAllowed(url);
        if (!allowed.allowed) {
          throw new Error(`URL disallowed by robots.txt: ${url}`);
        }
        await this.politenessManager.delay(allowed.crawlDelay);
      }

      // 0. Check cache (if enabled)
      let cacheHit = false;
      let cachedResult = null;

      if (this.cacheStore && options.useCache !== false) {
        cachedResult = this.cacheStore.get(url);

        if (cachedResult) {
          cacheHit = true;
          this.log(`Cache hit for ${url}`);

          // Update cache stats
          if (!this.stats.cacheHits) this.stats.cacheHits = 0;
          if (!this.stats.cacheMisses) this.stats.cacheMisses = 0;
          this.stats.cacheHits++;

          // Return cached result with metadata
          const duration = Date.now() - startTime;
          return {
            success: true,
            url,
            markdown: cachedResult.data.markdown,
            metadata: {
              type: cachedResult.data.metadata?.type || 'cached',
              confidence: cachedResult.data.metadata?.confidence || 1.0,
              frameworks: cachedResult.data.metadata?.frameworks || [],
              method: 'cache',
              length: cachedResult.data.markdown.length,
              savedPath: cachedResult.data.metadata?.savedPath || null,
              durationMs: duration,
              timestamp: new Date().toISOString(),
              cacheHit: true,
              cacheAge: Date.now() - cachedResult.createdAt
            },
            detection: cachedResult.data.metadata?.detection || { type: 'cached' },
            extraction: cachedResult.data.metadata?.extraction || { method: 'cache' },
            cached: true
          };
        } else {
          this.log(`Cache miss for ${url}`);
          if (!this.stats.cacheMisses) this.stats.cacheMisses = 0;
          this.stats.cacheMisses++;
        }
      }

      // 1. Detect page type
      this.log('Detecting page type...');
      const detection = await this.detector.detectFromUrl(url, options);

      if (!detection.success) {
        throw new Error(`Detection failed: ${detection.error}`);
      }

      const { classification } = detection;
      this.log(`Detected: ${classification.type} (${classification.confidence * 100}% confidence)`);

      // 2. Suggest extraction method
      const methodSuggestion = this.detector.suggestExtractionMethod(classification);
      this.log(`Suggested method: ${methodSuggestion.method} (${methodSuggestion.reason})`);

      // 3. Extract content
      let content;

      // Map legacy option for compatibility
      if (options.useBrowserHeadless !== undefined && options.useOpenClawBrowser === undefined) {
        options.useOpenClawBrowser = options.useBrowserHeadless;
      }

      // Priority: playwright > web_fetch > openclaw-browser
      if (methodSuggestion.method === 'playwright' && options.usePlaywright) {
        content = await this.extractWithPlaywright(url, methodSuggestion);
      } else if (methodSuggestion.method === 'browser_headless' && options.useOpenClawBrowser) {
        content = await this.extractWithBrowserHeadless(url, methodSuggestion);
      } else if (methodSuggestion.method === 'web_fetch' && options.useWebFetch) {
        content = await this.extractWithWebFetch(url, methodSuggestion);
      } else {
        // Hybrid or fallback - try in order of preference
        if (options.usePlaywright) {
          content = await this.extractWithPlaywright(url, methodSuggestion);
        } else if (options.useWebFetch) {
          content = await this.extractWithWebFetch(url, {});
        } else if (options.useOpenClawBrowser) {
          content = await this.extractWithBrowserHeadless(url, methodSuggestion);
        } else {
          throw new Error('No extraction method enabled (usePlaywright, useWebFetch, or useOpenClawBrowser must be true)');
        }
      }

      // Optional: download and localize images
      if (options.downloadImages) {
        this.log('Downloading and localizing images...');
        content.html = await this.downloadAndLocalizeImages(content.html, url);
      }

      const langDir = this.extractLanguageAndDirection(content.html);
      // 4. Convert to markdown
      this.log('Converting to markdown...');
      const markdown = this.convertHtmlToMarkdown(content.html);

      // 5. Save to file
      let savedPath = null;
      if (options.saveToFile) {
        savedPath = this.saveResult(url, markdown, {
          type: classification.type,
          confidence: classification.confidence,
          frameworks: classification.frameworks,
          language: langDir.language,
          direction: langDir.direction,
          method: content.method,
          extractionMetadata: content.metadata
        }, content.html);

        if (savedPath) {
          this.log(`Saved to: ${savedPath}`);
        }
      }

      // 6. Store in cache (if enabled)
      if (this.cacheStore && options.useCache !== false && !cacheHit) {
        const cacheData = {
          markdown,
          metadata: {
            type: classification.type,
            confidence: classification.confidence,
            frameworks: classification.frameworks,
            method: content.method,
            language: langDir.language,
            direction: langDir.direction,
            savedPath,
            detection: classification,
            extraction: content
          }
        };

        // Determine TTL based on content type (news articles shorter, documentation longer)
        let ttl = options.cacheTTL;
        if (classification.type === 'news' || classification.type === 'blog') {
          ttl = 6 * 60 * 60 * 1000; // 6 hours for news
        } else if (classification.type === 'documentation' || classification.type === 'article') {
          ttl = 7 * 24 * 60 * 60 * 1000; // 7 days for documentation
        }

        this.cacheStore.set(url, cacheData, ttl);
        this.log(`Stored in cache with TTL ${ttl / (60 * 60 * 1000)} hours`);
      }

      // 7. Update stats
      this.updateStats(classification.type, content.method, true);

      const duration = Date.now() - startTime;

      return {
        success: true,
        url,
        markdown,
        metadata: {
          type: classification.type,
          confidence: classification.confidence,
          frameworks: classification.frameworks,
          language: langDir.language,
          direction: langDir.direction,
          method: content.method,
          length: markdown.length,
          savedPath,
          durationMs: duration,
          timestamp: new Date().toISOString(),
          cacheHit: false
        },
        detection: classification,
        extraction: content
      };

    } catch (error) {
      this.log(`Conversion failed: ${error.message}`);
      this.updateStats('error', 'failed', false);

      const duration = Date.now() - startTime;

      return {
        success: false,
        url,
        error: error.message,
        metadata: {
          type: 'error',
          method: 'failed',
          durationMs: duration,
          timestamp: new Date().toISOString()
        }
      };
    }
  }  async batchConvert(urls, userOptions = {}) {
    // Extract batch-specific options
    const {
      parallel = 1,
      batchDelay = 1000,
      onProgress,
      progressInterval,
      stopOnError = false,
      ...conversionOptions
    } = userOptions;

    this.log(`Starting batch conversion of ${urls.length} URLs`);

    const results = [];
    const batches = [];

    // Create batches for parallel processing
    for (let i = 0; i < urls.length; i += parallel) {
      batches.push(urls.slice(i, i + parallel));
    }

    let processed = 0;
    const total = urls.length;

    // Optional: call onProgress at start
    if (typeof onProgress === 'function') {
      onProgress({ processed: 0, total, url: null, phase: 'start' });
    }

    // Process batches
    for (const batch of batches) {
      const batchPromises = batch.map(url =>
        this.convertUrlToMarkdown(url, conversionOptions)
          .then(result => {
            processed++;
            // Call progress callback
            if (typeof onProgress === 'function') {
              onProgress({
                processed,
                total,
                url,
                result,
                error: result.success ? undefined : result.error
              });
            }
            return result;
          })
          .catch(error => {
            processed++;
            const errorResult = {
              success: false,
              url,
              error: error.message,
              metadata: { type: 'error', method: 'failed' }
            };
            if (typeof onProgress === 'function') {
              onProgress({
                processed,
                total,
                url,
                result: errorResult,
                error: error.message
              });
            }
            return errorResult;
          })
      );

      const batchResults = await Promise.all(batchPromises);
      results.push(...batchResults);

      // Small delay between batches if configured and there are more batches
      if (batchDelay > 0 && batches.length > 1) {
        await new Promise(resolve => setTimeout(resolve, batchDelay));
      }
    }

    // Generate batch report
    const successCount = results.filter(r => r.success).length;
    const failureCount = results.filter(r => !r.success).length;

    this.log(`Batch complete: ${successCount} successful, ${failureCount} failed`);

    const finalResult = {
      success: failureCount === 0,
      total,
      successful: successCount,
      failed: failureCount,
      results,
      stats: this.getStats()
    };

    // Optional: call onProgress at end
    if (typeof onProgress === 'function') {
      onProgress({ processed: total, total, url: null, phase: 'end', finalResult });
    }

    return finalResult;
  }

  /**
   * Generate safe filename for image URL
   */
  generateImageFilename(url) {
    try {
      const urlObj = new URL(url);
      const hash = crypto.createHash('sha256').update(url).digest('hex').slice(0, 8);
      const ext = path.extname(urlObj.pathname).toLowerCase();
      const validExts = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.svg', '.bmp', '.ico'];
      const extension = validExts.includes(ext) ? ext : '.jpg';
      return `img-${hash}${extension}`;
    } catch (err) {
      this.log(`Error generating filename for ${url}: ${err.message}`);
      // Fallback
      return `img-${Date.now()}.jpg`;
    }
  }

  /**
   * Download image to local path with retry logic
   */
  async downloadImage(url, localPath) {
    const maxRetries = this.options.imageDownloadRetries;
    const retryDelay = this.options.imageDownloadRetryDelay;

    for (let attempt = 1; attempt <= maxRetries; attempt++) {
      try {
        // Politeness check
        if (this.politenessManager) {
          const allowed = await this.politenessManager.isAllowed(url);
          if (!allowed.allowed) {
            throw new Error(`Image URL disallowed by robots.txt: ${url}`);
          }
          await this.politenessManager.delay(allowed.crawlDelay);
        }

        await this._downloadImageSingle(url, localPath);
        // Resize image if needed
        await this._resizeImageIfNeeded(localPath);
        return; // success
      } catch (error) {
        if (error._isRedirect) {
          // Redirect to new URL
          return await this.downloadImage(error.redirectUrl, localPath);
        }

        this.log(`Download attempt ${attempt}/${maxRetries} failed: ${error.message}`);
        if (attempt === maxRetries) {
          throw new Error(`Failed to download image after ${maxRetries} attempts: ${error.message}`);
        }
        await new Promise(resolve => setTimeout(resolve, retryDelay));
      }
    }
  }

  /**
   * Resize image if sharp is available and dimensions exceed limits
   * Preserves original image format; skips vector formats (SVG) and animations (GIF)
   * @private
   */
  async _resizeImageIfNeeded(localPath) {
    if (!this.isSharpAvailable()) {
      return;
    }
    const maxWidth = this.options.imageMaxWidth;
    const maxHeight = this.options.imageMaxHeight;
    const quality = this.options.imageQuality;
    if (maxWidth === Infinity && maxHeight === Infinity) {
      return;
    }
    try {
      const sharp = require('sharp');
      const image = sharp(localPath);
      const metadata = await image.metadata();
      const { width, height, format } = metadata;

      // Skip resizing for vector formats and animations
      if (format === 'svg' || format === 'gif' || format === 'pdf') {
        this.log(`Skipping resizing for ${format.toUpperCase()} image: ${localPath}`);
        return;
      }

      if (!width || !height) {
        this.log(`Image dimensions unknown for ${localPath}, skipping resize`);
        return;
      }

      if (width <= maxWidth && height <= maxHeight) {
        return; // No resizing needed
      }

      // Calculate new dimensions preserving aspect ratio
      const ratio = Math.min(maxWidth / width, maxHeight / height);
      const newWidth = Math.round(width * ratio);
      const newHeight = Math.round(height * ratio);

      this.log(`Resizing image ${localPath} from ${width}x${height} to ${newWidth}x${newHeight} (format: ${format}, quality: ${quality})`);

      // Prepare resize pipeline
      let pipeline = image.resize(newWidth, newHeight, { fit: 'inside', withoutEnlargement: true });

      // Apply format-specific output options
      switch (format) {
        case 'jpeg':
        case 'jpg':
          pipeline = pipeline.jpeg({ quality });
          break;
        case 'png':
          // PNG compression level (0-9), map quality (0-100) to compression (0-9)
          const compression = Math.floor((100 - quality) / 100 * 9);
          pipeline = pipeline.png({ compressionLevel: compression });
          break;
        case 'webp':
          pipeline = pipeline.webp({ quality });
          break;
        case 'avif':
          pipeline = pipeline.avif({ quality });
          break;
        case 'tiff':
          pipeline = pipeline.tiff({ quality });
          break;
        case 'heif':
          pipeline = pipeline.heif({ quality });
          break;
        default:
          // For other formats (bmp, raw, etc.) keep as is, no format-specific options
          this.log(`No format-specific options for ${format}, keeping default`);
      }

      const tmpPath = localPath + '.tmp';
      await pipeline.toFile(tmpPath);

      // Replace original with resized version
      fs.unlinkSync(localPath);
      fs.renameSync(tmpPath, localPath);

      this.log(`Resized image saved: ${localPath}`);
    } catch (error) {
      this.log(`Image resize failed for ${localPath}: ${error.message}`);
      // Keep original image
    }
  }

  /**
   * Single attempt at downloading an image (handles redirects via error)
   * @private
   */
  _downloadImageSingle(url, localPath) {
    return new Promise((resolve, reject) => {
      const protocol = url.startsWith('https') ? https : http;
      const options = {
        headers: {
          'User-Agent': 'OpenClawDomToMarkdown/1.0'
        },
        timeout: 10000
      };

      const req = protocol.get(url, options, (res) => {
        if (res.statusCode >= 300 && res.statusCode < 400 && res.headers.location) {
          // Redirect - reject with special error
          const redirectError = new Error(`Redirect to ${res.headers.location}`);
          redirectError._isRedirect = true;
          redirectError.redirectUrl = res.headers.location;
          reject(redirectError);
          return;
        }
        if (res.statusCode !== 200) {
          reject(new Error(`HTTP ${res.statusCode}`));
          return;
        }

        const fileStream = fs.createWriteStream(localPath);
        res.pipe(fileStream);
        fileStream.on('finish', () => {
          fileStream.close();
          this.log(`Downloaded ${url} -> ${localPath} (${res.headers['content-length'] || 'unknown'} bytes)`);
          resolve();
        });
        fileStream.on('error', reject);
      });

      req.on('error', reject);
      req.on('timeout', () => {
        req.destroy();
        reject(new Error('Timeout'));
      });
    });
  }

  /**
   * Download images in HTML and replace src with local paths
   */
  async downloadAndLocalizeImages(html, baseUrl) {
    const parse5 = require('parse5');
    const document = parse5.parseFragment(html);

    // Collect image nodes
    const imageNodes = [];
    const traverse = (node) => {
      if (node.tagName === 'img' && node.attrs) {
        imageNodes.push(node);
      }
      if (node.childNodes) {
        for (const child of node.childNodes) {
          traverse(child);
        }
      }
    };
    traverse(document);

    const outputDir = this.getOutputDirForUrl(baseUrl);
    const imagesDir = path.join(outputDir, this.options.imageOutputDir);
    if (!fs.existsSync(imagesDir)) {
      fs.mkdirSync(imagesDir, { recursive: true });
    }

    const downloaded = new Map(); // url -> relativePath

    for (const imgNode of imageNodes) {
      const srcAttr = imgNode.attrs.find(attr => attr.name === 'src');
      if (!srcAttr || !srcAttr.value) continue;
      const src = srcAttr.value;

      // Skip data URLs
      if (src.startsWith('data:')) continue;

      // Resolve absolute URL
      let absoluteUrl;
      try {
        absoluteUrl = new URL(src, baseUrl).href;
      } catch (err) {
        this.log(`Invalid image URL: ${src}`);
        continue;
      }

      // Already downloaded in this page?
      if (downloaded.has(absoluteUrl)) {
        srcAttr.value = downloaded.get(absoluteUrl);
        continue;
      }

      // Generate filename and local path
      const filename = this.generateImageFilename(absoluteUrl);
      const localPath = path.join(imagesDir, filename);
      const relativePath = path.join(this.options.imageOutputDir, filename);

      // Check global cache for previously downloaded images
      if (this.downloadedImagesCache.has(absoluteUrl)) {
        const cached = this.downloadedImagesCache.get(absoluteUrl);
        // cached: { absoluteLocalPath, relativePath }
        // Check if file still exists
        if (fs.existsSync(cached.absoluteLocalPath)) {
          // Determine if we need to copy to current imagesDir
          if (cached.absoluteLocalPath !== localPath) {
            // Copy to current images directory
            fs.copyFileSync(cached.absoluteLocalPath, localPath);
            this.log(`Copied cached image ${absoluteUrl} to ${localPath}`);
          }
          // Use relative path (same as cached.relativePath)
          srcAttr.value = cached.relativePath;
          downloaded.set(absoluteUrl, cached.relativePath);
          this.log(`Reused cached image ${absoluteUrl} as ${cached.relativePath}`);
          continue;
        } else {
          // Cached file missing, remove from cache and proceed to download
          this.downloadedImagesCache.delete(absoluteUrl);
          this.log(`Cached file missing for ${absoluteUrl}, will download`);
        }
      }

      try {
        await this.downloadImage(absoluteUrl, localPath);
        srcAttr.value = relativePath;
        downloaded.set(absoluteUrl, relativePath);
        // Store in global cache
        this.downloadedImagesCache.set(absoluteUrl, {
          absoluteLocalPath: localPath,
          relativePath: relativePath
        });
        this.log(`Replaced ${src} with ${relativePath} (cached)`);
      } catch (error) {
        this.log(`Failed to download ${absoluteUrl}: ${error.message}`);
        // Keep original src
      }
    }

    return parse5.serialize(document);
  }

  /**
   * Get output directory for a given URL (domain-based)
   */
  getOutputDirForUrl(url) {
    const urlObj = new URL(url);
    const domain = urlObj.hostname.replace(/^www\./, '');
    const safeDomain = domain.replace(/[^a-z0-9]/gi, '-');
    const date = new Date().toISOString().split('T')[0];
    return path.join(this.options.outputDir, date, safeDomain);
  }
}

// Export main function
async function convertUrlToMarkdown(url, options = {}) {
  const converter = new DomToMarkdownConverter(options);
  return await converter.convertUrlToMarkdown(url, options);
}

// Export batch function
async function batchConvert(urls, options = {}) {
  const converter = new DomToMarkdownConverter(options);
  return await converter.batchConvert(urls, options);
}

module.exports = {
  DomToMarkdownConverter,
  convertUrlToMarkdown,
  batchConvert
};